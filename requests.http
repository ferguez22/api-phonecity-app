### Variables ###
@host = http://localhost:3000
@usuario = phonecity
@password = phonecity123.

###############################################
# 1. LOGIN  (pulsa "Send Request" AQUI primero)
###############################################
# @name login
POST {{host}}/api/auth/login
Content-Type: application/json

{
  "nombre_usuario": "{{usuario}}",
  "password": "{{password}}"
}

###############################################
# LINEAS
###############################################

### Health (publico)
GET {{host}}/api/health

### Listar todas
GET {{host}}/api/lineas
Authorization: Bearer {{login.response.body.data.token}}

### Filtrar + ordenar
GET {{host}}/api/lineas?flujo=pieza&orderBy=fecha_entrada&order=asc
Authorization: Bearer {{login.response.body.data.token}}

### orderBy invalido -> 400
GET {{host}}/api/lineas?orderBy=basura
Authorization: Bearer {{login.response.body.data.token}}

### Sin token -> 401
GET {{host}}/api/lineas

### Ver una linea
GET {{host}}/api/lineas/1
Authorization: Bearer {{login.response.body.data.token}}

###############################################
# CLIENTES (1.2)
###############################################

### Listar clientes
GET {{host}}/api/clientes
Authorization: Bearer {{login.response.body.data.token}}

### Buscar cliente (nombre o telefono)
GET {{host}}/api/clientes?q=Pepe
Authorization: Bearer {{login.response.body.data.token}}

### Crear cliente
POST {{host}}/api/clientes
Authorization: Bearer {{login.response.body.data.token}}
Content-Type: application/json

{
  "nombre": "Pepe Jimenez",
  "telefono": "653796129"
}

### Crear cliente con telefono repetido -> 409
POST {{host}}/api/clientes
Authorization: Bearer {{login.response.body.data.token}}
Content-Type: application/json

{
  "nombre": "Otro Pepe",
  "telefono": "653796129"
}

### Editar cliente
PUT {{host}}/api/clientes/1
Authorization: Bearer {{login.response.body.data.token}}
Content-Type: application/json

{
  "nombre": "Pepe Jimenez Corregido"
}

### Borrar cliente (409 si tiene reparaciones)
DELETE {{host}}/api/clientes/1
Authorization: Bearer {{login.response.body.data.token}}

### Crear linea PARA ese cliente (comprueba el JOIN)
POST {{host}}/api/lineas
Authorization: Bearer {{login.response.body.data.token}}
Content-Type: application/json

{
  "tienda_id": 1,
  "flujo": "reparacion",
  "fase": "no_reparable",
  "modelo": "Redmi 13C",
  "problema_o_pieza": "Tapa Trasera",
  "importe": 50,
  "fecha_entrada": "2026-01-20",
  "cliente_id": 4
}

### Listar lineas -> ahora trae cliente_nombre y cliente_telefono
GET {{host}}/api/lineas
Authorization: Bearer {{login.response.body.data.token}}

###############################################
# CREDENCIALES (1.3) — anidadas bajo la linea
###############################################

### Ver credenciales de una linea (404 si no tiene)
GET {{host}}/api/lineas/1/credenciales
Authorization: Bearer {{login.response.body.data.token}}

### Crear/actualizar credenciales (upsert)
PUT {{host}}/api/lineas/1/credenciales
Authorization: Bearer {{login.response.body.data.token}}
Content-Type: application/json

{
  "pin_sim": "1234",
  "codigo_desbloqueo": "patron L invertida",
  "correos_google": "cliente@gmail.com",
  "password_recuperacion": "recupera123"
}

### Volver a ver -> ahora existen
GET {{host}}/api/lineas/1/credenciales
Authorization: Bearer {{login.response.body.data.token}}

### Borrar credenciales manualmente
DELETE {{host}}/api/lineas/1/credenciales
Authorization: Bearer {{login.response.body.data.token}}

### RGPD: entregar la linea -> respuesta trae credenciales_borradas:true
PUT {{host}}/api/lineas/15
Authorization: Bearer {{login.response.body.data.token}}
Content-Type: application/json

{
  "fase": "entregado"
}

###############################################
# HISTORIAL DE ESTADOS
###############################################

### Ver la linea de tiempo de una linea
GET {{host}}/api/lineas/15/historial
Authorization: Bearer {{login.response.body.data.token}}



###############################################
# NOTAS (fase 1)
###############################################

### Listar notas (solo pendientes)
GET {{host}}/api/notas
Authorization: Bearer {{login.response.body.data.token}}

### Listar notas (incluye resueltas)
GET {{host}}/api/notas?incluir_resueltas=true
Authorization: Bearer {{login.response.body.data.token}}

### Crear nota
POST {{host}}/api/notas
Authorization: Bearer {{login.response.body.data.token}}
Content-Type: application/json

{
  "texto": "Avisar a cliente del cargador"
}

### Editar texto de nota
PUT {{host}}/api/notas/2
Authorization: Bearer {{login.response.body.data.token}}
Content-Type: application/json

{
  "texto": "Avisar a cliente del cargador iPhone 14"
}

### Resolver nota
PUT {{host}}/api/notas/2
Authorization: Bearer {{login.response.body.data.token}}
Content-Type: application/json

{
  "resuelto": true
}

### Reabrir nota
PUT {{host}}/api/notas/2
Authorization: Bearer {{login.response.body.data.token}}
Content-Type: application/json

{
  "resuelto": false
}

### Texto vacio -> 400
POST {{host}}/api/notas
Authorization: Bearer {{login.response.body.data.token}}
Content-Type: application/json

{
  "texto": "   "
}